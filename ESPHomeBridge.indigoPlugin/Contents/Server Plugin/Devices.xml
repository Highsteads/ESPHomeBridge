<?xml version="1.0" encoding="UTF-8"?>
<!-- ESPHome Bridge Plugin - Devices.xml                                              -->
<!-- v0.4.0 architecture: ONE Indigo device per ESPHome node (Tasmota-style).         -->
<!-- The device type matches the node's primary control entity (Lock > Climate >      -->
<!-- Switch > Light > Fan > Cover > else esphomeNode). All other entities become      -->
<!-- custom states on that single device, declared dynamically via getDeviceStateList -->
<!-- from the entityKeyMap JSON stored in pluginProps.                                 -->
<Devices>

    <!-- ============================================================
         Shared ConfigUI snippet (copy-pasted into each Device since
         Indigo's XML has no include mechanism):
           address          MAC (12-char uppercase, no separators)
           hostname         ESPHome node hostname
           ip / port        Native API endpoint
           encryptionKey    Base64 noise_psk (blank for plaintext)
           boardModel       e.g. esp32dev, esp8285
           esphomeVersion   e.g. 2026.4.5
           entityKeyMap     hidden JSON {state_id: {key, kind, name, ...}}
         ============================================================ -->

    <!-- ============================================================
         esphomeNode - info-only node (no primary control entity)
         ============================================================ -->
    <Device type="custom" id="esphomeNode">
        <Name>ESPHome Node (info-only)</Name>
        <ConfigUI>
            <Field id="address" type="textfield" defaultValue="">
                <Label>MAC Address:</Label>
            </Field>
            <Field id="hostname" type="textfield" defaultValue="">
                <Label>Hostname:</Label>
            </Field>
            <Field id="ip" type="textfield" defaultValue="">
                <Label>IP Address:</Label>
            </Field>
            <Field id="port" type="textfield" defaultValue="6053">
                <Label>API Port:</Label>
            </Field>
            <Field id="encryptionKey" type="textfield" defaultValue="">
                <Label>API Encryption Key (Base64):</Label>
                <Description>From the device's YAML api: encryption: key: line. Leave blank for unencrypted API.</Description>
            </Field>
            <Field id="boardModel" type="textfield" readonly="true" defaultValue="">
                <Label>Board:</Label>
            </Field>
            <Field id="esphomeVersion" type="textfield" readonly="true" defaultValue="">
                <Label>ESPHome Version:</Label>
            </Field>
            <Field id="entityKeyMap" type="textfield" hidden="true" defaultValue=""/>
        </ConfigUI>
        <States>
            <State id="connected">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Connected Changed</TriggerLabel>
                <ControlPageLabel>Connected</ControlPageLabel>
            </State>
            <State id="status">
                <ValueType>String</ValueType>
                <TriggerLabel>Status Changed</TriggerLabel>
                <ControlPageLabel>Status</ControlPageLabel>
            </State>
            <State id="lastSeen">
                <ValueType>String</ValueType>
                <TriggerLabel>Last Seen Changed</TriggerLabel>
                <ControlPageLabel>Last Seen</ControlPageLabel>
            </State>
        </States>
        <UiDisplayStateId>status</UiDisplayStateId>
    </Device>

    <!-- ============================================================
         esphomeSensor - sensor-class node (no controllable primary, but has
         sensors — e.g. a relay-less power-monitor plug). The headline reading
         (chosen by device_class priority) drives the native sensorValue; all
         other entities are custom states. SupportsSensorValue is set in props
         at creation (hidden XML defaults are NOT applied by device.create), so
         do NOT declare a <State id="sensorValue"> here — it is native.
         ============================================================ -->
    <Device type="sensor" id="esphomeSensor">
        <Name>ESPHome Sensor Node</Name>
        <ConfigUI>
            <Field id="address" type="textfield" defaultValue=""><Label>MAC Address:</Label></Field>
            <Field id="hostname" type="textfield" defaultValue=""><Label>Hostname:</Label></Field>
            <Field id="ip" type="textfield" defaultValue=""><Label>IP Address:</Label></Field>
            <Field id="port" type="textfield" defaultValue="6053"><Label>API Port:</Label></Field>
            <Field id="encryptionKey" type="textfield" defaultValue="">
                <Label>API Encryption Key (Base64):</Label>
                <Description>From the device's YAML api: encryption: key: line. Leave blank for unencrypted API.</Description>
            </Field>
            <Field id="boardModel" type="textfield" readonly="true" defaultValue=""><Label>Board:</Label></Field>
            <Field id="esphomeVersion" type="textfield" readonly="true" defaultValue=""><Label>ESPHome Version:</Label></Field>
            <Field id="unit" type="textfield" readonly="true" defaultValue=""><Label>Headline Unit:</Label></Field>
            <Field id="SupportsSensorValue" type="checkbox" hidden="true" defaultValue="true"/>
            <Field id="SupportsOnState" type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="entityKeyMap" type="textfield" hidden="true" defaultValue=""/>
        </ConfigUI>
        <States>
            <State id="connected">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Connected Changed</TriggerLabel>
                <ControlPageLabel>Connected</ControlPageLabel>
            </State>
            <State id="status">
                <ValueType>String</ValueType>
                <TriggerLabel>Status Changed</TriggerLabel>
                <ControlPageLabel>Status</ControlPageLabel>
            </State>
            <State id="lastSeen">
                <ValueType>String</ValueType>
                <TriggerLabel>Last Seen Changed</TriggerLabel>
                <ControlPageLabel>Last Seen</ControlPageLabel>
            </State>
        </States>
    </Device>

    <!-- ============================================================
         esphomeSwitch - relay-class node (primary entity = Switch)
         ============================================================ -->
    <Device type="relay" id="esphomeSwitch">
        <Name>ESPHome Switch Node</Name>
        <ConfigUI>
            <Field id="address" type="textfield" defaultValue=""><Label>MAC Address:</Label></Field>
            <Field id="hostname" type="textfield" defaultValue=""><Label>Hostname:</Label></Field>
            <Field id="ip" type="textfield" defaultValue=""><Label>IP Address:</Label></Field>
            <Field id="port" type="textfield" defaultValue="6053"><Label>API Port:</Label></Field>
            <Field id="encryptionKey" type="textfield" defaultValue="">
                <Label>API Encryption Key (Base64):</Label>
                <Description>From the device's YAML api: encryption: key: line. Leave blank for unencrypted API.</Description>
            </Field>
            <Field id="boardModel" type="textfield" readonly="true" defaultValue=""><Label>Board:</Label></Field>
            <Field id="esphomeVersion" type="textfield" readonly="true" defaultValue=""><Label>ESPHome Version:</Label></Field>
            <Field id="entityKeyMap" type="textfield" hidden="true" defaultValue=""/>
        </ConfigUI>
        <States>
            <State id="connected">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Connected Changed</TriggerLabel>
                <ControlPageLabel>Connected</ControlPageLabel>
            </State>
            <State id="status">
                <ValueType>String</ValueType>
                <TriggerLabel>Status Changed</TriggerLabel>
                <ControlPageLabel>Status</ControlPageLabel>
            </State>
            <State id="lastSeen">
                <ValueType>String</ValueType>
                <TriggerLabel>Last Seen Changed</TriggerLabel>
                <ControlPageLabel>Last Seen</ControlPageLabel>
            </State>
        </States>
    </Device>

    <!-- ============================================================
         esphomeLight - dimmer-class node (primary entity = Light)
         ============================================================ -->
    <Device type="dimmer" id="esphomeLight">
        <Name>ESPHome Light Node</Name>
        <ConfigUI>
            <Field id="address" type="textfield" defaultValue=""><Label>MAC Address:</Label></Field>
            <Field id="hostname" type="textfield" defaultValue=""><Label>Hostname:</Label></Field>
            <Field id="ip" type="textfield" defaultValue=""><Label>IP Address:</Label></Field>
            <Field id="port" type="textfield" defaultValue="6053"><Label>API Port:</Label></Field>
            <Field id="encryptionKey" type="textfield" defaultValue="">
                <Label>API Encryption Key (Base64):</Label>
            </Field>
            <Field id="boardModel" type="textfield" readonly="true" defaultValue=""><Label>Board:</Label></Field>
            <Field id="esphomeVersion" type="textfield" readonly="true" defaultValue=""><Label>ESPHome Version:</Label></Field>
            <Field id="SupportsColor" type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="SupportsRGB" type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="SupportsWhite" type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="SupportsWhiteTemperature" type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="entityKeyMap" type="textfield" hidden="true" defaultValue=""/>
        </ConfigUI>
        <States>
            <State id="connected"><ValueType>Boolean</ValueType><TriggerLabel>Connected Changed</TriggerLabel><ControlPageLabel>Connected</ControlPageLabel></State>
            <State id="status"><ValueType>String</ValueType><TriggerLabel>Status Changed</TriggerLabel><ControlPageLabel>Status</ControlPageLabel></State>
            <State id="colorTemp"><ValueType>Integer</ValueType><TriggerLabel>Color Temp Changed</TriggerLabel><ControlPageLabel>Color Temp</ControlPageLabel></State>
            <State id="lastSeen"><ValueType>String</ValueType><TriggerLabel>Last Seen Changed</TriggerLabel><ControlPageLabel>Last Seen</ControlPageLabel></State>
        </States>
    </Device>

    <!-- ============================================================
         esphomeFan - dimmer-class node (primary entity = Fan, speed)
