    <!-- ============================================================
         esphomeClimate - thermostat-class node (primary = Climate)
         ============================================================ -->
    <Device type="thermostat" id="esphomeClimate">
        <Name>ESPHome Climate Node</Name>
        <ConfigUI>
            <Field id="address" type="textfield" defaultValue=""><Label>MAC Address:</Label></Field>
