            <State id="oscillating"><ValueType>Boolean</ValueType><TriggerLabel>Oscillating Changed</TriggerLabel><ControlPageLabel>Oscillating</ControlPageLabel></State>
            <State id="direction"><ValueType>String</ValueType><TriggerLabel>Direction Changed</TriggerLabel><ControlPageLabel>Direction</ControlPageLabel></State>
            <State id="lastSeen"><ValueType>String</ValueType><TriggerLabel>Last Seen Changed</TriggerLabel><ControlPageLabel>Last Seen</ControlPageLabel></State>
        </States>
    </Device>

    <!-- ============================================================
         esphomeCover - dimmer-class node (primary entity = Cover)
