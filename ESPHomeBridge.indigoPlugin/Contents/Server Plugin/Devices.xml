            <Field id="ip" type="textfield" defaultValue=""><Label>IP Address:</Label></Field>
            <Field id="port" type="textfield" defaultValue="6053"><Label>API Port:</Label></Field>
            <Field id="encryptionKey" type="textfield" defaultValue=""><Label>API Encryption Key (Base64):</Label></Field>
            <Field id="boardModel" type="textfield" readonly="true" defaultValue=""><Label>Board:</Label></Field>
            <Field id="esphomeVersion" type="textfield" readonly="true" defaultValue=""><Label>ESPHome Version:</Label></Field>
            <Field id="speedLevels" type="textfield" readonly="true" defaultValue="0"><Label>Speed Levels:</Label></Field>
            <Field id="supportsOscillation" type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="supportsDirection" type="checkbox" hidden="true" defaultValue="false"/>
            <Field id="entityKeyMap" type="textfield" hidden="true" defaultValue=""/>
